{
  "name": "app-igreja",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "engines": {
    "node": ">=20.19.4"
  },
  "scripts": {
    "start": "expo start",
    "start:lan": "expo start --host lan",
    "metro:watch": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/metro-lan-watchdog.ps1",
    "metro:watch:install": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/install-metro-watchdog-task.ps1",
    "metro:watch:uninstall": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/uninstall-metro-watchdog-task.ps1",
    "reset-project": "node ./scripts/reset-project.js",
    "web": "expo start --web --port 8081",
    "web:8083": "expo start --web --port 8083",
    "build:family-form": "vite build --config standalone/cadastro-familia/vite.config.ts",
    "dev:family-form": "vite --config standalone/cadastro-familia/vite.config.ts",
    "build:web": "npm run generate:icons && expo export -p web && npm run build:family-form",
    "generate:icons": "node scripts/generate-app-icons.mjs",
    "build:docs:md": "node scripts/build-pacotes-md.mjs",
    "build:docs:pdf": "node scripts/build-pacotes-pdf.mjs",
    "build:docs": "node scripts/build-pacotes-md.mjs && node scripts/build-pacotes-pdf.mjs",
    "lint": "expo lint"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@expo/vector-icons": "^15.0.3",
    "@hookform/resolvers": "^5.4.0",
    "@radix-ui/react-label": "^2.1.9",
    "@radix-ui/react-slot": "^1.2.5",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-picker/picker": "2.11.1",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "@supabase/supabase-js": "^2.106.1",
    "base64-arraybuffer": "^1.0.2",
    "buffer": "^6.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "docx": "^9.7.1",
    "expo": "~54.0.0",
    "expo-camera": "~17.0.10",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
