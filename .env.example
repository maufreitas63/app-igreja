# Produção: nega acesso quando RPCs de ACL não estão instaladas (fail-closed).
EXPO_PUBLIC_ACL_STRICT=true

# Opcional: melhora geocodificação de CEP (senão usa ViaCEP + OpenStreetMap).
EXPO_PUBLIC_GOOGLE_MAPS_GEOCODING_API_KEY=

# Opcional: tiles Google Maps no Android/iOS (build nativo).
EXPO_PUBLIC_GOOGLE_MAPS_ANDROID_API_KEY=
EXPO_PUBLIC_GOOGLE_MAPS_IOS_API_KEY=
